<section class="browse-hero">
  <div class="browse-hero-content">
    <p class="eyebrow">Inside your vault</p>

    <h1>My Collection</h1>

    <p>
      View your collected amiibo and save personal reviews.
    </p>
  </div>
</section>

<section class="browse-section">

  <% if (amiibos.length === 0) { %>

    <div class="empty-library">
      <i class="fa-regular fa-heart"></i>

      <h2>Your collection is empty</h2>

      <p>
        Browse the catalog and click a heart to add an amiibo.
      </p>

      <a class="primary-button" href="/amiibos">
        Browse Amiibos
      </a>
    </div>

  <% } else { %>

    <div
      class="amiibo-grid"
      id="amiibo-grid"
      data-authenticated="true"
    >

      <% amiibos.forEach((amiibo) => { %>

        <%
          const amiiboId =
            `${amiibo.head}-${amiibo.tail}`;

          const savedReview =
            reviewMap[amiiboId] || null;
        %>

        <article
          class="amiibo-card collection-review-card"
          data-head="<%= amiibo.head %>"
          data-tail="<%= amiibo.tail %>"
        >

          <div class="amiibo-image-wrapper">
            <img
              class="amiibo-image"
              src="<%= amiibo.image %>"
              alt="<%= amiibo.name %>"
              loading="lazy"
            >

            <span class="amiibo-type-badge">
              <%= amiibo.type %>
            </span>
          </div>

          <div class="amiibo-card-content">

            <div class="amiibo-card-heading">
              <div>
                <h2><%= amiibo.name %></h2>

                <p class="amiibo-character">
                  <%= amiibo.character %>
                </p>
              </div>

              <button
                class="icon-button collection-button selected"
                type="button"
                data-selected="true"
                title="Remove from collection"
                aria-label="Remove this amiibo from the collection"
              >
                <i class="fa-solid fa-heart"></i>
              </button>
            </div>

            <div class="amiibo-details">
              <p>
                <span>Game Series</span>
                <strong><%= amiibo.gameSeries %></strong>
              </p>

              <p>
                <span>Amiibo Series</span>
                <strong><%= amiibo.amiiboSeries %></strong>
              </p>
            </div>

            <div class="review-panel">
              <h3>
                <%= savedReview ? "Edit Review" : "Add Review" %>
              </h3>

              <form
                class="review-form"
                method="POST"
                action="/reviews"
              >
                <input
                  type="hidden"
                  name="head"
                  value="<%= amiibo.head %>"
                >

                <input
                  type="hidden"
                  name="tail"
                  value="<%= amiibo.tail %>"
                >

                <div class="form-group">
                  <label
                    for="rating-<%= amiibo.head %>-<%= amiibo.tail %>"
                  >
                    Rating
                  </label>

                  <select
                    id="rating-<%= amiibo.head %>-<%= amiibo.tail %>"
                    name="rating"
                    required
                  >
                    <option value="">Choose a rating</option>

                    <% for (let rating = 1; rating <= 5; rating += 1) { %>
                      <option
                        value="<%= rating %>"
                        <%= savedReview?.rating === rating ? "selected" : "" %>
                      >
                        <%= rating %> / 5
                      </option>
                    <% } %>
                  </select>
                </div>

                <div class="form-group">
                  <label
                    for="review-<%= amiibo.head %>-<%= amiibo.tail %>"
                  >
                    Review
                  </label>

                  <textarea
                    id="review-<%= amiibo.head %>-<%= amiibo.tail %>"
                    name="reviewText"
                    minlength="3"
                    maxlength="500"
                    rows="4"
                    required
                  ><%= savedReview?.review || "" %></textarea>
                </div>

                <button
                  class="primary-button review-save-button"
                  type="submit"
                >
                  <i class="fa-solid fa-floppy-disk"></i>

                  <%= savedReview ? "Update Review" : "Save Review" %>
                </button>
              </form>

              <% if (savedReview) { %>
                <form
                  class="delete-review-form"
                  method="POST"
                  action="/reviews/<%= savedReview.review_id %>/delete"
                >
                  <button
                    class="delete-review-button"
                    type="submit"
                    onclick="return confirm('Delete this review?');"
                  >
                    <i class="fa-solid fa-trash"></i>
                    Delete Review
                  </button>
                </form>
              <% } %>
            </div>

          </div>

        </article>

      <% }) %>

    </div>

  <% } %>

</section>