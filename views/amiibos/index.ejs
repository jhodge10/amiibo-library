<section class="browse-hero">
  <div class="browse-hero-content">
    <p class="eyebrow">Explore the catalog</p>

    <h1>Browse Amiibos</h1>

    <p>
      Search the vault and save amiibo to your wishlist
      or personal collection.
    </p>
  </div>
</section>

<section class="browse-section">

  <div class="filter-panel">

    <div class="filter-heading">
      <div>
        <h2>Find an Amiibo</h2>

        <p>
          Search by name or narrow the results using
          the available filters.
        </p>
      </div>

      <button
        class="clear-filters-button"
        id="clear-filters"
        type="button"
      >
        <i class="fa-solid fa-rotate-left"></i>
        Clear Filters
      </button>
    </div>

    <div class="filter-controls">

      <div class="form-group search-group">
        <label for="amiibo-search">Search</label>

        <div class="input-with-icon">
          <i class="fa-solid fa-magnifying-glass"></i>

          <input
            id="amiibo-search"
            type="search"
            placeholder="Search by name or character..."
            autocomplete="off"
          >
        </div>
      </div>

      <div class="form-group">
        <label for="series-filter">Game Series</label>

        <select id="series-filter">
          <option value="">All Game Series</option>

          <% const gameSeries = [...new Set(
            amiibos
              .map((amiibo) => amiibo.gameSeries)
              .filter(Boolean)
          )].sort(); %>

          <% gameSeries.forEach((series) => { %>
            <option value="<%= series.toLowerCase() %>">
              <%= series %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="type-filter">Amiibo Type</label>

        <select id="type-filter">
          <option value="">All Types</option>

          <% const amiiboTypes = [...new Set(
            amiibos
              .map((amiibo) => amiibo.type)
              .filter(Boolean)
          )].sort(); %>

          <% amiiboTypes.forEach((type) => { %>
            <option value="<%= type.toLowerCase() %>">
              <%= type %>
            </option>
          <% }) %>
        </select>
      </div>

    </div>
  </div>

  <div class="results-toolbar">
    <p>
      Showing
      <strong id="visible-count"><%= amiibos.length %></strong>
      of
      <strong><%= amiibos.length %></strong>
      amiibo
    </p>

    <% if (!currentUser) { %>
      <p class="phase-message">
        Log in to save wishlist and collection selections.
      </p>
    <% } %>
  </div>

  <div
    class="amiibo-grid"
    id="amiibo-grid"
    data-authenticated="<%= currentUser ? 'true' : 'false' %>"
  >

    <% amiibos.forEach((amiibo) => { %>

      <% const amiiboId = `${amiibo.head}-${amiibo.tail}`; %>
      <% const inWishlist = wishlistIds.includes(amiiboId); %>
      <% const inCollection = collectionIds.includes(amiiboId); %>

      <article
        class="amiibo-card"
        data-name="<%= amiibo.name.toLowerCase() %>"
        data-character="<%= amiibo.character.toLowerCase() %>"
        data-series="<%= amiibo.gameSeries.toLowerCase() %>"
        data-type="<%= amiibo.type.toLowerCase() %>"
        data-head="<%= amiibo.head %>"
        data-tail="<%= amiibo.tail %>"
      >

        <div class="amiibo-image-wrapper">
          <img
            class="amiibo-image"
            src="<%= amiibo.image %>"
            alt="<%= amiibo.name %>"
            loading="lazy"
          >

          <span class="amiibo-type-badge">
            <%= amiibo.type %>
          </span>
        </div>

        <div class="amiibo-card-content">

          <div class="amiibo-card-heading">
            <div>
              <h2><%= amiibo.name %></h2>

              <p class="amiibo-character">
                <%= amiibo.character %>
              </p>
            </div>

            <div class="amiibo-actions">

              <button
                class="icon-button wishlist-button <%= inWishlist ? 'selected' : '' %>"
                type="button"
                title="<%= inWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>"
                data-selected="<%= inWishlist %>"
                aria-label="<%= inWishlist ? 'Remove this amiibo from the wishlist' : 'Add this amiibo to the wishlist' %>"
              >
                <i class="<%= inWishlist ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
              </button>

              <button
                class="icon-button collection-button <%= inCollection ? 'selected' : '' %>"
                type="button"
                title="<%= inCollection ? 'Remove from collection' : 'Add to collection' %>"
                data-selected="<%= inCollection %>"
                aria-label="<%= inCollection ? 'Remove this amiibo from the collection' : 'Add this amiibo to the collection' %>"
              >
                <i class="<%= inCollection ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
              </button>

            </div>
          </div>

          <div class="amiibo-details">
            <p>
              <span>Game Series</span>
              <strong><%= amiibo.gameSeries %></strong>
            </p>

            <p>
              <span>Amiibo Series</span>
              <strong><%= amiibo.amiiboSeries %></strong>
            </p>
          </div>

        </div>

      </article>

    <% }) %>

  </div>

  <div class="no-results" id="no-results" hidden>
    <i class="fa-solid fa-magnifying-glass"></i>

    <h2>No amiibo found</h2>

    <p>
      Try changing your search or clearing the filters.
    </p>

    <button
      class="secondary-button"
      id="no-results-clear"
      type="button"
    >
      Clear Filters
    </button>
  </div>

</section>