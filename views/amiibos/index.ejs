<%- include('../partials/header') %>

<h1>All Amiibos</h1>

<div>
  <% amiibos.forEach(amiibo => { %>

    <div style="margin-bottom:20px;">
      <img
        src="<%= amiibo.image %>"
        alt="<%= amiibo.name %>"
        width="100"
      >

      <h3><%= amiibo.name %></h3>

      <p>
        Character:
        <%= amiibo.character %>
      </p>

      <p>
        Series:
        <%= amiibo.amiiboSeries %>
      </p>

      <hr>
    </div>

  <% }) %>
</div>

<%- include('../partials/footer') %>